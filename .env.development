# npm run dev 시 로그인 화면에「개발용 바로 입장」표시 (프로덕션 빌드에는 포함되지 않음)
VITE_DEV_MOCK_AUTH=false

# 실백엔드가 GET/PATCH /api/me/quests* 를 제공할 때: Vite 인메모리 퀘스트 스텁 끔(유저별 DB 수치)
# 스텁만 쓰려면 true 또는 이 줄 삭제(기본은 스텁 켜짐)
VITE_EMBEDDED_QUEST_STUB=false

# 필요 시 메인 API 주소 (미설정 시 vite.config.js 기본 127.0.0.1:8888)
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8888
