# 로컬: 비워 두면 /api 는 Vite 프록시 사용 (vite.config.js)
# 배포: 프론트·API 도메인이 다를 때만 설정
# VITE_API_BASE_URL=https://api.example.com
# VITE_QUEST_API_BASE_URL=https://quest.example.com

# Vite 개발 서버 프록시 대상 (터미널에서만 사용)
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8888
# VITE_DEV_QUEST_API_URL=http://127.0.0.1:8787

# 개발 시 /api/me/quests* 를 Vite 인메모리 스텁으로 처리 (기본: 켜짐). 실제 백엔드에 동일 API가 있으면 false
# VITE_EMBEDDED_QUEST_STUB=false

# 참조 백엔드 단독: npm run server:quest-ref (기본 포트 8889)
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8889 npm run dev
